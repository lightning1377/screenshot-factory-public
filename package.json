{
  "name": "screenshot-factory",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade screenshot generation for Capacitor apps",
  "main": "dist/index.js",
  "bin": {
    "screenshot-runner": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/dev-server.ts",
    "build": "tsc --project tsconfig.build.json",
    "build:frontend": "tsc --project tsconfig.frontend.json",
    "start": "node dist/index.js",
    "docs:screenshots": "tsx scripts/generate-readme-screenshots.ts",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/index.ts"
  },
  "keywords": [
    "capacitor",
    "screenshots",
    "google-play",
    "puppeteer",
    "automation"
  ],
  "author": {
    "name": "Siavash Kahe",
    "email": "s.kahe98@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@grapesjs/studio-sdk": "^1.0.57",
    "@preact/signals": "^2.8.1",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^8.2.12",
    "@types/sortablejs": "^1.15.9",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "googleapis": "^171.4.0",
    "inquirer": "^8.2.7",
    "preact": "^10.28.3",
    "puppeteer": "^24.36.1",
    "sortablejs": "^1.15.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@capacitor/app": "^8.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "happy-dom": "^20.6.2",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vite-express": "^0.22.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}